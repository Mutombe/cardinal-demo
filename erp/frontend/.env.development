# Development environment variables
# These are used when running `npm run dev`

# Empty → relative /api through the Vite proxy (same-origin; no CORS/cookie issues).
# Proxy target is 127.0.0.1:8000 (vite.config.ts), so run the backend on :8000.
VITE_API_URL=

# Public website homepage — the ERP root (/) redirects here in dev.
VITE_WEB_URL=http://localhost:5174
